{
  "extends": "stylelint-config-standard",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "layer",
          "apply",
          "variants",
          "responsive",
          "screen",
          "theme",
          "custom-variant"
        ]
      }
    ],
    "function-no-unknown": null,
    "declaration-block-no-duplicate-properties": true
  }
}
